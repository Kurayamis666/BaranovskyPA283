{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Запуск приложения",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Python: Тесты",
            "type": "debugpy",
            "request": "launch",
            "module": "unittest",
            "args": ["discover", "-s", "tests", "-p", "test_*.py"],
            "console": "integratedTerminal"
        },
        {
            "name": "Python: Отладка импорта",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/utils/import_data.py",
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}